        {
          "name": "Error — File Too Large (413)",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": "{{sit_file_path}}",
                  "description": "Upload a file larger than max_upload_size_mb (default 20 MB) to trigger this error."
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/api/v1/validate",
              "host": ["{{base_url}}"],
              "path": ["api", "{{api_version}}", "validate"]
            },
            "description": "Uploads a file that exceeds the configured `max_upload_size_mb` limit (default 20 MB).\n\nExpected: `413 Request Entity Too Large` with `{\"error\": \"file too large, max 20MB\"}`"
          },
          "response": [
            {
              "name": "413 — file too large",
              "status": "Request Entity Too Large",
              "code": 413,
              "header": [{"key": "Content-Type", "value": "application/json; charset=utf-8"}],
              "body": "{\"error\": \"file too large, max 20MB\"}",
              "_postman_previewlanguage": "json"
            }
          ],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 413', function () {",
                  "    pm.response.to.have.status(413);",
                  "});",
                  "",
                  "pm.test('Error mentions file too large', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.error).to.include('file too large');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}
